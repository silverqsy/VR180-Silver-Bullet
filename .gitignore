# Rust
/target/
**/target/
**/*.rs.bk
Cargo.lock.bak

# Compiled Swift helper binaries — these are built by helpers/build_swift.sh,
# not committed. (Source .swift files ARE committed.)
/helpers/bin/
helpers/swift/mvhevc_encode
helpers/swift/vt_denoise
helpers/swift/apac_encode

# OS detritus
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Local override / experiment files
/scratch/
/local-config.json

# avbuild / ffmpeg distribution (kept out of git; user points FFMPEG_DIR at it)
/ffmpeg/

# Reference / sample footage (multi-GB .360 files for local validation;
# never tracked — too large for git, and not redistributable anyway).
/test 360 files/
/samples/
/*.360
/*.mp4
/*.mov

# Verification / debug artifacts (examples + manual runs write these to the
# repo root or crate dir; never source). PNG/JPG/log dumps, raw pixel dumps.
/*.png
/*.jpg
/*.log
/build_log.txt
*.rgba64
/crates/vr180-pipeline/src/colorcheck.mp4
/crates/vr180-pipeline/src/colorcheck*.png

# Local verification scaffolding — handy on Windows, but several of these
# examples are Windows/CUDA-only and would break the macOS `--all-targets`
# build. Kept local; not part of the handoff.
/crates/vr180-pipeline/examples/

# Release bundling output (signed .app / .zip / .dmg) — produced locally by
# the macOS release process; ship via GitHub Releases, never the repo.
/dist/
