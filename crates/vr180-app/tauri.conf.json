{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VR180 Silver Bullet Neo",
  "version": "0.1.0",
  "identifier": "io.silverqsy.vr180neo",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VR180 Silver Bullet Neo",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Video",
    "copyright": "© 2026 silverqsy",
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
